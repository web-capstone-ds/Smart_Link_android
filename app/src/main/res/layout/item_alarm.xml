<?xml version="1.0" encoding="utf-8"?>
<!-- LOT 알람 타임라인 아이템 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <!-- 심각도 점 -->
    <View
        android:id="@+id/alarm_severity_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginTop="5dp"
        android:background="@color/color_fail" />

    <!-- 알람 내용 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <!-- 시각 + 타입 + 심각도 행 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_alarm_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_alarm_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.04" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" · " android:textColor="@color/text_secondary" android:textSize="9sp" />

            <TextView
                android:id="@+id/tv_alarm_severity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_fail"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <!-- 알람 타이틀 -->
        <TextView
            android:id="@+id/tv_alarm_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_fail"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp" />

        <!-- 알람 설명 -->
        <TextView
            android:id="@+id/tv_alarm_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="3dp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>
</LinearLayout>
