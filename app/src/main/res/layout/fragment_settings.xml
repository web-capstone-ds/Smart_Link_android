<?xml version="1.0" encoding="utf-8"?>
<!-- 설정 Fragment (Settings.tsx 대응) -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_phone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── 사용자 정보 카드 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="로그인 계정"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:layout_marginBottom="12dp" />

            <!-- 이름 행 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingVertical="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="이름" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border_light" />

            <!-- 사번 행 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingVertical="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="사번" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_emp_id"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/color_info" android:textSize="13sp" android:fontFamily="monospace" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border_light" />

            <!-- 부서 행 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingVertical="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="부서" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_department"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border_light" />

            <!-- 역할 행 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingVertical="8dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="역할" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_role"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="24dp" />

        <!-- ── 앱 정보 카드 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="앱 정보"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:layout_marginBottom="12dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="6dp">
                <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                    android:text="버전" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1.0.0 (API 24+)" android:textColor="@color/text_primary" android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="6dp">
                <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                    android:text="데이터 소스" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MQTT / REST API (Mock)" android:textColor="@color/text_primary"
                    android:textSize="12sp" android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="32dp" />

        <!-- ── 로그아웃 버튼 ── -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="로그아웃"
            android:textColor="@color/color_fail"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_logout_button"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
