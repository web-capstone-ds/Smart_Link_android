<?xml version="1.0" encoding="utf-8"?>
<!-- 보고서 Fragment (ReportScreen.tsx 대응) -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_phone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── 일일 / 주간 탭 버튼 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_daily"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="일일 보고서"
                android:textSize="12sp"
                android:background="@drawable/bg_tab_selected"
                android:textColor="@color/color_info"
                android:elevation="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_weekly"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="주간 보고서"
                android:textSize="12sp"
                android:background="@drawable/bg_tab_unselected"
                android:textColor="@color/text_secondary"
                android:elevation="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- ── 보고 기간 ── -->
        <TextView
            android:id="@+id/tv_report_period"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="12dp" />

        <!-- ── LOT 통계 카드 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="14dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOT 현황"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.06" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <!-- 전체 LOT -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView
                        android:id="@+id/tv_total_lots"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="전체 LOT" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>

                <!-- 합격 LOT -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView
                        android:id="@+id/tv_pass_lots"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/color_pass" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="합격" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>

                <!-- 불합격 LOT -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView
                        android:id="@+id/tv_fail_lots"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/color_fail" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="불합격" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>

                <!-- LOT 불합격률 -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView
                        android:id="@+id/tv_fail_rate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/color_marginal" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="불합격률" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 유닛 통계 행 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView
                        android:id="@+id/tv_total_units"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                        android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="총 검사 유닛" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView
                        android:id="@+id/tv_unit_fail_rate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/color_marginal" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="유닛 불합격률" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── 주요 불량 유형 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="주요 불량 유형"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_defects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- ── 라인별 통계 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="라인별 통계"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_line_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- ── 서버 자동 분석 코멘트 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="서버 자동 분석"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_oracle_comment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
