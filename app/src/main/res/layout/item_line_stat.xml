<?xml version="1.0" encoding="utf-8"?>
<!-- 라인별 통계 아이템 (ReportScreen lineStats 대응) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_dark"
    android:layout_marginVertical="3dp"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <!-- 상태 점 -->
    <View
        android:id="@+id/line_status_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@color/color_pass" />

    <!-- 라인 정보 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp">

        <TextView
            android:id="@+id/tv_line_alias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_line_eq_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- LOT 통계 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/tv_line_total_lots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_line_fail_lots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- 불합격률 + 상태 -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_line_fail_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_fail"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_line_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
