<?xml version="1.0" encoding="utf-8"?>
<!-- 장비 상태 아이템 (EquipmentStatus 카드 대응) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_dark"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    android:padding="14dp">

    <!-- 상태 점 -->
    <View
        android:id="@+id/eq_status_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginTop="4dp"
        android:background="@color/color_pass" />

    <!-- 장비 정보 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <!-- 장비 별칭 + 상태 행 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_eq_alias"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_eq_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 장비 ID -->
        <TextView
            android:id="@+id/tv_eq_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />

        <!-- 수율 + 최종 점검 행 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_eq_yield"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_eq_last_check"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 진행도 바 -->
        <ProgressBar
            android:id="@+id/progress_eq"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:progressTint="@color/color_info"
            android:progressBackgroundTint="@color/border"
            android:max="100" />

        <TextView
            android:id="@+id/tv_eq_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</LinearLayout>
