<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_phone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minHeight="760dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="0dp"
        android:paddingBottom="20dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/bg_login_top_line" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_login_hero">

            <ImageView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:src="@drawable/ic_nav_dashboard"
                android:padding="18dp"
                android:background="@drawable/bg_login_icon"
                app:tint="@color/color_info"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="SMART FACTORY"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="10sp"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="비전검사 대시보드"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="28sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="사번과 비밀번호로 로그인하세요"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 위 spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.4" />

        <!-- 폼 묶음 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:padding="16dp"
                android:background="@drawable/bg_card_dark">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="사번 (Employee ID)"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etEmployeeId"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="8dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="예) EMP001"
                    android:inputType="textCapCharacters"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="비밀번호"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toStartOf="@id/btnTogglePw"
                        android:paddingStart="14dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="비밀번호 입력"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:background="@android:color/transparent" />

                    <ImageButton
                        android:id="@+id/btnTogglePw"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="@color/text_secondary"
                        android:contentDescription="@string/cd_toggle_password" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_error_box"
                    android:textColor="@color/color_fail"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="로그인"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@null"
                    app:backgroundTint="@null"
                    android:elevation="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="비밀번호 변경"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:background="@drawable/bg_card_dark" />
        </LinearLayout>

        <!-- 아래 spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>