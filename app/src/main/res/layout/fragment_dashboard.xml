<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_phone"
    android:orientation="vertical"
    android:paddingTop="68dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_nav_dashboard"
            android:tint="@color/color_info" />

        <TextView
            android:id="@+id/tv_dashboard_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="&#xBE44;&#xC804;&#xAC80;&#xC0AC; &#xB300;&#xC2DC;&#xBCF4;&#xB4DC;"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_theme_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_header_icon_button"
            android:contentDescription="Theme toggle"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_theme_light"
            android:tint="@color/color_info" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical|end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_user_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMP001"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="USER"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btn_logout"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Logout"
                    android:padding="2dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_logout_line"
                    android:tint="@color/text_secondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_mqtt_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_fail"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="MQTT DISCONNECTED"
                android:textColor="@color/color_fail"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_dept_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_meta_chip_operator"
            android:ellipsize="end"
            android:maxLines="1"
            android:gravity="center"
            android:textAlignment="center"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="A&#xB3D9; &#xAD00;&#xB9AC;&#xC790;  010-0000-0000"
            android:textColor="@color/color_info"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_mes_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_meta_chip"
            android:ellipsize="end"
            android:maxLines="1"
            android:gravity="center"
            android:textAlignment="center"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="&#xC11C;&#xBC84; MES &#xC5F0;&#xACB0;&#xB428;"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/divider_meta"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="10dp"
        android:background="@color/section_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_count_fail"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_badge_fail"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="1dp"
                android:text="0&#10;FAIL"
                android:textAlignment="center"
                android:textColor="@color/color_fail"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_count_marginal"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_badge_marginal"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="1dp"
                android:text="0&#10;WARN"
                android:textAlignment="center"
                android:textColor="@color/color_marginal"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_count_pass"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_badge_pass"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="1dp"
                android:text="0&#10;합격"
                android:textAlignment="center"
                android:textColor="@color/color_pass"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_count_idle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_meta_chip"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="1dp"
                android:text="0&#10;정지/대기"
                android:textAlignment="center"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_live_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="OFFLINE"
            android:textColor="@color/color_fail"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/divider_status"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="10dp"
        android:background="@color/section_divider" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_dashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="10dp" />

</LinearLayout>
